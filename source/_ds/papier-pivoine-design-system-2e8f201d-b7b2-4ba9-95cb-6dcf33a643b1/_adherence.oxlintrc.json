{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/surfaces/**",
              "ui_kits/journal/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Aboreto|Albert Sans))/i]",
        "message": "Font not provided by the design system. Available: Aboreto, Albert Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|fullWidth|iconStart|iconEnd|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, fullWidth, iconStart, iconEnd, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|soft|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'soft' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|interactive|padded|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, interactive, padded, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|blush|warm)$/]",
        "message": "<Card> tone must be one of 'paper' | 'blush' | 'warm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, onChange, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:ornament|tone|spacing|style|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: ornament, tone, spacing, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sage|rose|faint)$/]",
        "message": "<Divider> tone must be one of 'sage' | 'rose' | 'faint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LetterBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|signature|align|style|key|ref|className|style|children)$/]",
        "message": "<LetterBlock> doesn't accept that prop. Declared props: children, signature, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LetterBlock'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<LetterBlock> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PivoineBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|active|style|key|ref|className|style|children)$/]",
        "message": "<PivoineBadge> doesn't accept that prop. Declared props: variant, active, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PivoineBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:strip|list)$/]",
        "message": "<PivoineBadge> variant must be one of 'strip' | 'list'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sage|rose|olive|outline)$/]",
        "message": "<Tag> tone must be one of 'sage' | 'rose' | 'olive' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|rows|ruled|id|style|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, value, onChange, placeholder, rows, ruled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|value|onChange|placeholder|type|id|disabled|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, hint, value, onChange, placeholder, type, id, disabled, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
